@push('css')
<style>
/* ═══════════════════════════════════════════════
   NOMALY TRAVEL — 2025 Design System
   Navy + Gold Luxury Theme
═══════════════════════════════════════════════ */
:root {
    --nm-navy:      #0a1628;
    --nm-navy2:     #0f2347;
    --nm-gold:      #c9a84c;
    --nm-gold-lt:   #e8c96a;
    --nm-gold-pale: #f5edd8;
    --nm-white:     #ffffff;
    --nm-gray:      #f4f6fa;
    --nm-text:      #2c3e50;
}

/* ── Hero ─────────────────────────────────── */
.nm-hero {
    min-height: 100vh;
    background:
        linear-gradient(160deg, rgba(10,22,40,0.82) 0%, rgba(15,35,71,0.70) 100%),
        url('https://images.unsplash.com/photo-1436491865332-7a61a109cc05?w=1920&q=80') center/cover no-repeat;
    display: flex;
    align-items: center;
    padding: 110px 0 60px;
    position: relative;
}
.nm-hero-tagline { font-size:14px; letter-spacing:4px; text-transform:uppercase; color:var(--nm-gold); font-weight:700; margin-bottom:10px; }
.nm-hero-title { font-size:clamp(2.2rem, 5vw, 3.8rem); font-weight:900; color:#fff; line-height:1.1; margin-bottom:8px; }
.nm-hero-sub { font-size:1.25rem; color:rgba(255,255,255,0.85); font-weight:400; margin-bottom:36px; letter-spacing:0.3px; }
.nm-hero-sub span { color:var(--nm-gold); font-weight:700; }

/* ── Search Box ───────────────────────────── */
.nm-search-wrap {
    background: rgba(255,255,255,0.97);
    border-radius: 20px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.35);
    overflow: hidden;
    backdrop-filter: blur(10px);
}
.nm-search-tabs {
    display: flex;
    background: var(--nm-navy);
    border-radius: 0;
    border-bottom: none;
    overflow-x: auto;
}
.nm-search-tabs .nav-item { flex-shrink: 0; }
.nm-search-tabs .nav-link {
    color: rgba(255,255,255,0.65);
    border: none;
    border-radius: 0;
    padding: 14px 20px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.3px;
    transition: all .2s;
    white-space: nowrap;
    border-bottom: 3px solid transparent;
}
.nm-search-tabs .nav-link:hover { color: var(--nm-gold-lt); background: rgba(255,255,255,0.05); }
.nm-search-tabs .nav-link.active {
    color: var(--nm-gold);
    background: rgba(201,168,76,0.12);
    border-bottom: 3px solid var(--nm-gold);
}
.nm-search-tabs .nav-link i { margin-right: 6px; }
.nm-tab-body { padding: 24px 28px 22px; }
.nm-tab-body .form-control, .nm-tab-body .form-select {
    border: 1.5px solid #dde2ec;
    border-radius: 10px;
    height: 46px;
    font-size: 14px;
}
.nm-tab-body .form-control:focus { border-color: var(--nm-gold); box-shadow: 0 0 0 3px rgba(201,168,76,0.15); }
.nm-tab-body label { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; color: #666; margin-bottom: 6px; }
.nm-search-btn {
    background: linear-gradient(135deg, var(--nm-gold) 0%, var(--nm-gold-lt) 100%);
    color: var(--nm-navy);
    border: none;
    border-radius: 10px;
    height: 46px;
    font-weight: 800;
    font-size: 15px;
    width: 100%;
    letter-spacing: 0.3px;
    transition: all .2s;
    box-shadow: 0 4px 15px rgba(201,168,76,0.4);
}
.nm-search-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(201,168,76,0.5); }
.nm-trip-btns { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
.nm-trip-btn { padding: 6px 16px; border-radius: 20px; border: 1.5px solid #dde2ec; background: #fff; font-size: 13px; font-weight: 600; cursor: pointer; transition: all .15s; color: #555; }
.nm-trip-btn.active, .nm-trip-btn:hover { border-color: var(--nm-navy); background: var(--nm-navy); color: #fff; }

/* ── Trust Badges ─────────────────────────── */
.nm-trust-bar {
    background: var(--nm-navy);
    padding: 18px 0;
}
.nm-trust-item { display: flex; align-items: center; gap: 12px; color: #fff; }
.nm-trust-item i { font-size: 22px; color: var(--nm-gold); flex-shrink: 0; }
.nm-trust-item .nm-trust-title { font-size: 14px; font-weight: 700; margin: 0; }
.nm-trust-item .nm-trust-sub { font-size: 11px; color: rgba(255,255,255,0.6); margin: 0; }
.nm-trust-sep { width: 1px; background: rgba(255,255,255,0.15); height: 40px; }

/* ── Section Titles ───────────────────────── */
.nm-section { padding: 70px 0; }
.nm-section-alt { background: var(--nm-gray); }
.nm-section-title { text-align: center; margin-bottom: 40px; }
.nm-section-title .nm-eyebrow { font-size: 12px; letter-spacing: 4px; text-transform: uppercase; color: var(--nm-gold); font-weight: 700; margin-bottom: 8px; }
.nm-section-title h2 { font-size: clamp(1.7rem, 3vw, 2.4rem); font-weight: 900; color: var(--nm-navy); margin-bottom: 10px; }
.nm-section-title p { color: #666; font-size: 15px; max-width: 540px; margin: 0 auto; }

/* ── Destination Cards ────────────────────── */
.nm-dest-card {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    height: 260px;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    transition: transform .25s, box-shadow .25s;
}
.nm-dest-card:hover { transform: translateY(-5px); box-shadow: 0 12px 35px rgba(0,0,0,0.25); }
.nm-dest-img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; }
.nm-dest-card:hover .nm-dest-img { transform: scale(1.07); }
.nm-dest-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(10,22,40,0.85) 0%, rgba(10,22,40,0.1) 60%);
}
.nm-dest-info {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 20px 18px 16px;
}
.nm-dest-city { font-size: 20px; font-weight: 800; color: #fff; margin: 0; }
.nm-dest-state { font-size: 12px; color: var(--nm-gold); font-weight: 600; letter-spacing: 1px; text-transform: uppercase; }
.nm-dest-price { font-size: 12px; color: rgba(255,255,255,0.75); margin-top: 4px; }
.nm-dest-badge {
    position: absolute; top: 14px; right: 14px;
    background: var(--nm-gold);
    color: var(--nm-navy);
    font-size: 10px; font-weight: 800;
    padding: 3px 9px; border-radius: 20px;
    text-transform: uppercase; letter-spacing: 0.5px;
}

/* ── Event / Sports Cards ─────────────────── */
.nm-event-card {
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 3px 18px rgba(0,0,0,0.08);
    overflow: hidden;
    transition: transform .2s, box-shadow .2s;
}
.nm-event-card:hover { transform: translateY(-4px); box-shadow: 0 10px 30px rgba(0,0,0,0.14); }
.nm-event-img { width: 100%; height: 160px; object-fit: cover; }
.nm-event-body { padding: 16px; }
.nm-event-cat { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; color: var(--nm-gold); margin-bottom: 6px; }
.nm-event-title { font-size: 15px; font-weight: 700; color: var(--nm-navy); margin-bottom: 6px; }
.nm-event-meta { font-size: 12px; color: #888; }
.nm-event-price { font-size: 18px; font-weight: 900; color: var(--nm-navy); margin-top: 10px; }
.nm-event-price span { font-size: 11px; font-weight: 400; color: #999; }
.nm-event-btn {
    display: block; margin-top: 12px;
    background: var(--nm-navy); color: #fff;
    border-radius: 8px; padding: 9px 0; text-align: center;
    font-size: 13px; font-weight: 700; text-decoration: none;
    transition: background .2s;
    border: 2px solid var(--nm-gold);
}
.nm-event-btn:hover { background: var(--nm-gold); color: var(--nm-navy); }

/* ── Deal of the Day ─────────────────────── */
.nm-deal-section {
    background: linear-gradient(135deg, var(--nm-navy) 0%, var(--nm-navy2) 100%);
    padding: 70px 0;
    position: relative;
    overflow: hidden;
}
.nm-deal-section::before {
    content: '';
    position: absolute; inset: 0;
    background: url('https://images.unsplash.com/photo-1483450388369-9ed95738483c?w=1400&q=60') center/cover;
    opacity: 0.08;
}
.nm-deal-label { font-size: 12px; letter-spacing: 4px; text-transform: uppercase; color: var(--nm-gold); font-weight: 700; }
.nm-deal-title { font-size: clamp(1.8rem, 3vw, 2.6rem); font-weight: 900; color: #fff; margin: 10px 0; }
.nm-deal-sub { color: rgba(255,255,255,0.75); font-size: 15px; margin-bottom: 20px; }
.nm-deal-price-box { background: rgba(201,168,76,0.12); border: 1.5px solid var(--nm-gold); border-radius: 14px; padding: 20px 28px; display: inline-block; }
.nm-deal-from { font-size: 12px; color: var(--nm-gold); text-transform: uppercase; letter-spacing: 1px; font-weight: 700; }
.nm-deal-amount { font-size: 3rem; font-weight: 900; color: #fff; line-height: 1; }
.nm-deal-per { font-size: 12px; color: rgba(255,255,255,0.6); }
.nm-deal-btn {
    display: inline-block; padding: 14px 36px;
    background: var(--nm-gold); color: var(--nm-navy);
    border-radius: 12px; font-weight: 800; font-size: 15px;
    text-decoration: none; transition: all .2s;
    box-shadow: 0 4px 20px rgba(201,168,76,0.4);
}
.nm-deal-btn:hover { transform: translateY(-2px); background: var(--nm-gold-lt); color: var(--nm-navy); }
.nm-countdown { display: flex; gap: 16px; margin-bottom: 28px; }
.nm-cd-box { text-align: center; }
.nm-cd-num { font-size: 2rem; font-weight: 900; color: var(--nm-gold); line-height: 1; display: block; }
.nm-cd-lbl { font-size: 10px; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 1px; display: block; }
.nm-cd-sep { font-size: 1.8rem; color: var(--nm-gold); font-weight: 900; align-self: center; padding-bottom: 12px; }

/* ── Rewards ──────────────────────────────── */
.nm-rewards-section {
    background: linear-gradient(135deg, #0a1628 0%, #1a3a6b 100%);
    padding: 80px 0;
    position: relative;
    overflow: hidden;
}
.nm-rewards-section::after {
    content: '';
    position: absolute; top: -60px; right: -60px;
    width: 400px; height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(201,168,76,0.15) 0%, transparent 70%);
}
.nm-rewards-badge { font-size: 11px; letter-spacing: 4px; text-transform: uppercase; color: var(--nm-gold); font-weight: 700; margin-bottom: 10px; }
.nm-rewards-title { font-size: clamp(1.7rem, 3vw, 2.5rem); font-weight: 900; color: #fff; margin-bottom: 12px; }
.nm-rewards-sub { color: rgba(255,255,255,0.72); font-size: 15px; line-height: 1.7; max-width: 480px; }
.nm-reward-step { display: flex; align-items: flex-start; gap: 16px; margin-bottom: 24px; }
.nm-reward-icon { width: 52px; height: 52px; background: rgba(201,168,76,0.15); border: 1.5px solid var(--nm-gold); border-radius: 14px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.nm-reward-icon i { font-size: 20px; color: var(--nm-gold); }
.nm-reward-step-title { font-size: 15px; font-weight: 700; color: #fff; margin-bottom: 3px; }
.nm-reward-step-sub { font-size: 13px; color: rgba(255,255,255,0.6); }
.nm-rewards-join-btn {
    display: inline-block; padding: 15px 38px;
    background: var(--nm-gold); color: var(--nm-navy);
    border-radius: 12px; font-weight: 800; font-size: 16px;
    text-decoration: none; transition: all .2s;
    box-shadow: 0 4px 20px rgba(201,168,76,0.4);
    margin-top: 16px;
}
.nm-rewards-join-btn:hover { transform: translateY(-2px); background: var(--nm-gold-lt); color: var(--nm-navy); }
.nm-points-visual {
    background: rgba(255,255,255,0.05);
    border: 1.5px solid rgba(201,168,76,0.3);
    border-radius: 20px;
    padding: 30px;
    position: relative; z-index: 1;
}
.nm-points-card {
    background: linear-gradient(135deg, var(--nm-gold) 0%, var(--nm-gold-lt) 100%);
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 20px;
}
.nm-points-card-lbl { font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: rgba(10,22,40,0.7); }
.nm-points-card-num { font-size: 2.5rem; font-weight: 900; color: var(--nm-navy); line-height: 1.1; }
.nm-points-card-user { font-size: 14px; color: rgba(10,22,40,0.75); margin-top: 4px; }
.nm-tier-list { display: flex; flex-direction: column; gap: 10px; }
.nm-tier { display: flex; align-items: center; gap: 12px; padding: 10px 14px; border-radius: 10px; background: rgba(255,255,255,0.05); }
.nm-tier-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
.nm-tier-name { font-size: 13px; font-weight: 700; color: #fff; }
.nm-tier-pts { font-size: 11px; color: rgba(255,255,255,0.5); margin-left: auto; }

/* ── Airlines strip ───────────────────────── */
.nm-airlines-section { padding: 40px 0; background: #fff; border-top: 1px solid #eee; border-bottom: 1px solid #eee; }
.nm-airline-logo { height: 40px; object-fit: contain; filter: grayscale(1); opacity: 0.5; transition: all .2s; }
.nm-airline-logo:hover { filter: grayscale(0); opacity: 1; }

/* ── Footer Cta ──────────────────────────── */
.nm-cta-section { padding: 60px 0; background: var(--nm-gray); }
.nm-cta-card { background: linear-gradient(135deg, var(--nm-gold-pale) 0%, #fff 100%); border: 1.5px solid var(--nm-gold); border-radius: 20px; padding: 40px; }

/* ── Responsive tweaks ───────────────────── */
@media (max-width: 767px) {
    .nm-hero { padding: 100px 0 40px; min-height: auto; }
    .nm-trust-sep { display: none; }
    .nm-trust-item { justify-content: center; text-align: center; flex-direction: column; }
    .nm-deal-amount { font-size: 2.2rem; }
}
</style>
@endpush

<!-- ═══ HERO ═══════════════════════════════════ -->
<div class="nm-hero">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">

                <div class="text-center mb-4">
                    <p class="nm-hero-tagline">Your Journey Starts Here</p>
                    <h1 class="nm-hero-title">Fly. Stay. Experience.</h1>
                    <p class="nm-hero-sub"><span>All in One Place.</span> &mdash; Book flights, hotels, tours, sports & concerts.</p>
                </div>

                <!-- Search Box -->
                <div class="nm-search-wrap">
                    <ul class="nav nm-search-tabs" id="nm-tabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#nm-flights" type="button">
                                <i class="fas fa-plane"></i> Flights
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#nm-hotels" type="button">
                                <i class="fas fa-hotel"></i> Hotels
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <a class="nav-link" href="{{ url('/tours') }}">
                                <i class="fas fa-map-marked-alt"></i> Tours
                            </a>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#nm-sports" type="button">
                                <i class="fas fa-football-ball"></i> Sports Tickets
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#nm-concerts" type="button">
                                <i class="fas fa-music"></i> Concerts &amp; Events
                            </button>
                        </li>
                    </ul>

                    <div class="tab-content">

                        <!-- FLIGHTS TAB -->
                        <div class="tab-pane fade show active" id="nm-flights" role="tabpanel">
                            <div class="nm-tab-body">
                                <form action="{{ url('/flights/search') }}" method="GET">
                                    <div class="nm-trip-btns">
                                        <input type="radio" class="btn-check" name="triptype" id="nm-oneway" value="oneway" checked>
                                        <label class="nm-trip-btn" for="nm-oneway">One Way</label>
                                        <input type="radio" class="btn-check" name="triptype" id="nm-twoway" value="twoway">
                                        <label class="nm-trip-btn" for="nm-twoway">Round Trip</label>
                                        <input type="radio" class="btn-check" name="triptype" id="nm-multi" value="Multicity">
                                        <label class="nm-trip-btn" for="nm-multi">Multi-city</label>
                                    </div>
                                    <div class="row g-3 single-city">
                                        <div class="col-md-3">
                                            <label>From</label>
                                            <input type="text" id="nm_from_location" name="slices[0][from_location]" class="form-control" list="airports-list" autocomplete="off" placeholder="From: City or Airport">
                                            <input type="hidden" id="nm_from_code" name="slices[0][from]">
                                        </div>
                                        <div class="col-md-3">
                                            <label>To</label>
                                            <input type="text" id="nm_to_location" name="slices[0][to_location]" class="form-control" list="airports-list" autocomplete="off" placeholder="To: City or Airport">
                                            <input type="hidden" id="nm_to_code" name="slices[0][to]">
                                        </div>
                                        <div class="col-md-2">
                                            <label>Depart</label>
                                            <input type="date" name="slices[0][travelling_date]" id="nm_travel_date" class="form-control">
                                        </div>
                                        <div class="col-md-2 return-date" style="display:none;">
                                            <label>Return</label>
                                            <input name="return_date" type="text" id="nm_return_date" class="form-control" placeholder="Return date" autocomplete="off">
                                        </div>
                                        <div class="col-md-2">
                                            <label>Cabin</label>
                                            <select class="form-control" name="cabin_class">
                                                <option value="">Any</option>
                                                <option value="economy">Economy</option>
                                                <option value="premium_economy">Prem. Economy</option>
                                                <option value="business">Business</option>
                                                <option value="first">First Class</option>
                                            </select>
                                        </div>
                                        <div class="col-md-1">
                                            <label>Adults</label>
                                            <input type="number" class="form-control" name="adults" min="1" max="9" value="1">
                                        </div>
                                        <div class="col-md-1">
                                            <label>Children</label>
                                            <input type="number" class="form-control" name="children" min="0" max="9" value="0">
                                        </div>
                                        <div class="col-md-2 d-flex align-items-end">
                                            <button type="submit" class="nm-search-btn"><i class="fas fa-search me-2"></i>Search</button>
                                        </div>
                                    </div>
                                <datalist id="airports-list">
<option value="Atlanta ATL">
<option value="Los Angeles LAX">
<option value="Chicago ORD">
<option value="Chicago Midway MDW">
<option value="Dallas Fort Worth DFW">
