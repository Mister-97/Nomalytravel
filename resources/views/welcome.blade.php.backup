@inject('_tmSvc', 'App\Services\TicketmasterService')
@php
    $_tmResult = $_tmSvc->getSportsEvents([]);
    $_tmEvents = array_slice($_tmResult['events'] ?? [], 0, 3);
@endphp
<section class="nm-section nm-section-alt">
    <div class="container">
        <div class="nm-section-title">
            <p class="nm-eyebrow">Live Events</p>
            <h2>Featured Sports Tickets</h2>
            <p>Catch the biggest games live — real seats, real prices, powered by Ticketmaster.</p>
        </div>
        @if(count($_tmEvents) > 0)
        <div class="row g-3">
            @foreach($_tmEvents as $_ev)
            @php
                $_evImg   = collect($_ev['images'] ?? [])->firstWhere('ratio', '16_9')['url'] ?? ($_ev['images'][0]['url'] ?? null);
                $_evVenue = $_ev['_embedded']['venues'][0] ?? [];
                $_evCity  = ($_evVenue['city']['name'] ?? '') . (isset($_evVenue['state']['stateCode']) ? ', '.$_evVenue['state']['stateCode'] : '');
                $_evDate  = isset($_ev['dates']['start']['localDate']) ? \Carbon\Carbon::parse($_ev['dates']['start']['localDate'])->format('D, M j Y') : 'TBA';
                $_evTime  = isset($_ev['dates']['start']['localTime']) ? \Carbon\Carbon::parse($_ev['dates']['start']['localTime'])->format('g:i A') : '';
                $_evMin   = $_ev['priceRanges'][0]['min'] ?? null;
                $_evPrice = $_evMin ? '$'.number_format($_evMin, 0) : 'Check prices';
                $_evGenre = $_ev['classifications'][0]['genre']['name'] ?? ($_ev['classifications'][0]['segment']['name'] ?? 'Sports');
                $_evUrl   = $_ev['url'] ?? url('/sports');
            @endphp
            <div class="col-md-4">
                <div class="nm-event-card">
                    @if($_evImg)
                    <img class="nm-event-img" src="{{ $_evImg }}" alt="{{ $_ev['name'] }}" loading="lazy">
                    @else
                    <div class="nm-event-img" style="background:linear-gradient(135deg,#0a1628,#1a3a6b);display:flex;align-items:center;justify-content:center;font-size:2.5rem;">🏟</div>
                    @endif
                    <div class="nm-event-body">
                        <p class="nm-event-cat"><i class="fas fa-ticket-alt me-1"></i>{{ $_evGenre }}</p>
                        <h4 class="nm-event-title">{{ $_ev['name'] }}</h4>
                        <p class="nm-event-meta">
                            <i class="fas fa-calendar me-1"></i>{{ $_evDate }}{{ $_evTime ? ' · '.$_evTime : '' }}
                            @if($_evCity) &bull; <i class="fas fa-map-marker-alt me-1"></i>{{ $_evVenue['name'] ?? '' }}{{ $_evCity ? ', '.$_evCity : '' }}@endif
                        </p>
                        <div class="nm-event-price">{{ $_evPrice }} <span>/ ticket</span></div>
                        <a href="{{ $_evUrl }}" target="_blank" class="nm-event-btn"><i class="fas fa-ticket-alt me-1"></i>Get Tickets</a>
                    </div>
                </div>
            </div>
            @endforeach
        </div>
        @else
        <div class="row g-3">
            <div class="col-12 text-center py-4">
