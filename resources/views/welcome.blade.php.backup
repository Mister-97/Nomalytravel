<option value="Barcelona BCN">
<option value="Tokyo NRT">
<option value="Sydney SYD">
<option value="Toronto YYZ">
                                </datalist>
                                </form>
                            </div>
                        </div>

                        <!-- HOTELS TAB -->
                        <div class="tab-pane fade" id="nm-hotels" role="tabpanel">
                            <div class="nm-tab-body">
                                <form method="get" action="{{ route('hotels.search') }}">
                                    <div class="row g-3">
                                        <div class="col-md-5">
                                            <label>Destination</label>
                                            <select name="keyword" id="nm_hotel_dest" class="city-select" style="width:100%"><option value="">Destination City</option></select>
                                        </div>
                                        <div class="col-md-3">
                                            <label>Check-in</label>
                                            <input type="date" class="form-control" name="checkin" min="2026-03-31">
                                        </div>
                                        <div class="col-md-2">
                                            <label>Check-out</label>
                                            <input type="date" class="form-control" name="checkout" min="2026-04-01">
                                        </div>
                                        <div class="col-md-2 d-flex align-items-end">
                                            <button type="submit" class="nm-search-btn"><i class="fas fa-search me-2"></i>Search</button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>

                        <!-- SPORTS TICKETS TAB -->
                        <div class="tab-pane fade" id="nm-sports" role="tabpanel">
                            <div class="nm-tab-body">
                                <div class="row g-3">
